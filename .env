PROJECT_NAME=solyto
COMPOSE_PROJECT_NAME=${PROJECT_NAME}

SOLYTO_VERSION=latest

# Domains
API_DOMAIN=api.yourdomain.com
APP_DOMAIN=app.yourdomain.com
DAV_DOMAIN=dav.yourdomain.com
ACME_EMAIL=you@yourdomain.com

# API
APP_NAME=${PROJECT_NAME}
APP_URL=https://${APP_DOMAIN}
FRONTEND_URL=https://${APP_DOMAIN}
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=UTC
LOG_CHANNEL=stderr
PULSE_ENABLED=false
TELESCOPE_ENABLED=false

# App
NODE_ENV=production
PUBLIC_API_URL=https://${API_DOMAIN}

# Versions
MARIADB_VERSION=12
POSTGRES_VERSION=17
REDIS_VERSION=7.4.1
PHP_VERSION=8.4

# Databases
POSTGRES_USER=postgres
DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=api
DAV_DB_HOST=postgres
DAV_DB_PORT=5432
DAV_DB_DATABASE=dav

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_PREFIX=solyto_

# Misc
TIMEZONE=UTC
TZ=${TIMEZONE}

# AI (library recommendations)
# Set AI_BASE_URL to use a custom OpenAI-compatible endpoint (e.g. IONOS).
# Leave empty to use OpenAI directly.
AI_BASE_URL=
AI_MODEL=gpt-4o-mini

# Mail
MAILGUN_DOMAIN=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=
