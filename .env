PROJECT_NAME=solyto
COMPOSE_PROJECT_NAME=${PROJECT_NAME}

# Domains
API_DOMAIN=FILL THIS IN
APP_DOMAIN=FILL THIS IN

# API
APP_NAME=${PROJECT_NAME}
APP_URL=https://${APP_DOMAIN}
FRONTEND_URL=https://${APP_DOMAIN}
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=UTC
LOG_CHANNEL=stderr
PULSE_ENABLED=false
TELESCOPE_ENABLED=false

# App
NODE_ENV=production

# Versions
MARIADB_VERSION=12
POSTGRES_VERSION=17
REDIS_VERSION=7.4.1
PHP_VERSION=8.4

# Databases
POSTGRES_USER=postgres
DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=api
DAV_DB_HOST=postgres
DAV_DB_PORT=5432
DAV_DB_DATABASE=dav

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_PREFIX=solyto_

# Misc
TIMEZONE=UTC
TZ=${TIMEZONE}

# Mail
MAILGUN_DOMAIN=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=
